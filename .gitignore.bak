# =============================================================================
# Secrets & credentials — never commit these
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/

# =============================================================================
# Session data — runtime artefacts created by SessionLocalShellBackend
# Each session gets its own sandbox directory under sessions/
# =============================================================================
sessions/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
htmlcov/
.coverage
coverage.xml

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# uv
# =============================================================================
# uv.lock is intentionally committed — it pins exact dependency versions.
# Do NOT add uv.lock here.

# =============================================================================
# Jupyter notebooks (outputs can contain API responses / secrets)
# =============================================================================
*.ipynb

# =============================================================================
# OS artefacts
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Claude Code local settings (contain project-specific tool permissions)
# =============================================================================
.claude/
